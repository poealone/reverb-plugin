{
    "name": "Reverb",
    "author": "PocketDAW",
    "version": "1.0.0",
    "description": "Algorithmic stereo reverb — Freeverb-style 4 comb + 2 allpass per channel.",
    "type": "fx",
    "library": "reverb.so",
    "params": [
        { "name": "Size",    "default": 0.30, "widget": "knob", "orientation": "radial", "navGroup": "knobs", "navOrder": 0 },
        { "name": "Decay",   "default": 0.40, "widget": "knob", "orientation": "radial", "navGroup": "knobs", "navOrder": 1 },
        { "name": "Damp",    "default": 0.50, "widget": "knob", "orientation": "radial", "navGroup": "knobs", "navOrder": 2 },
        { "name": "PreDly",  "default": 0.05, "widget": "knob", "orientation": "radial", "navGroup": "knobs", "navOrder": 3 },
        { "name": "Mix",     "default": 0.30, "widget": "knob", "orientation": "radial", "navGroup": "knobs", "navOrder": 4 }
    ],
    "presets": [
        "Small Room", "Large Hall", "Plate", "Spring", "Cathedral"
    ],
    "ui": {
        "accent": [180, 110, 230],
        "layout": "knobs",
        "pages": true,
        "navGroups": {
            "knobs": { "layout": "horizontal", "wrap": false }
        }
    },
    "tags": ["reverb", "ambience", "space", "fx"]
}
